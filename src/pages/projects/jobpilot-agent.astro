---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sitePath } from "../../lib/site.js";

const structure = [
  "候选人画像、目标岗位和岗位 JD 进入 React 工作台。",
  "FastAPI 创建异步任务，并通过 SSE 返回节点进度。",
  "LangGraph 编排画像解析、JD 解析、混合召回、重排、评分、差距分析和简历建议。",
  "ChromaDB 向量召回与 TF-IDF 关键词召回通过 Weighted RRF 融合。",
  "Trace、延迟、Token、成本和离线评测结果用于复盘系统质量。",
];

const evidence = [
  "固定版本 BGE Embedding + TF-IDF + Weighted RRF 混合检索。",
  "规则重排、确定性匹配评分和可选 LLM Top-5 重排。",
  "LangGraph 条件路由、重试、降级、人工审核和 checkpoint。",
  "FastAPI 异步任务、SSE、取消、超时和运行隔离。",
  "Docker 与 Azure Container Apps 云端部署。"
];

const tags = ["Python 3.10", "LangGraph", "FastAPI", "React + Vite", "ChromaDB", "Weighted RRF", "Azure"];
---

<BaseLayout title="JobPilot-Agent | 项目" description="面向 AI Agent、RAG 与 LLM 应用实习岗位的智能匹配和简历优化系统。">
  <article class="article-page project-detail">
    <div class="project-showcase">
      <div class="project-media-stack">
        <img src={sitePath("projects/jobpilot-agent/ui.png")} alt="JobPilot-Agent 工作台界面" loading="lazy" />
        <img src={sitePath("projects/jobpilot-agent/architecture.png")} alt="JobPilot-Agent 系统架构图" loading="lazy" />
      </div>

      <section class="project-story">
        <header class="article-header project-header">
          <p class="eyebrow">AI Agent / RAG</p>
          <h1>JobPilot-Agent</h1>
          <p class="tagline">岗位匹配与简历优化 RAG-Agent 工作台</p>
          <p>
            JobPilot 使用 React + FastAPI 提供交互式工作台，以 LangGraph 编排候选人画像、JD 解析、
            混合召回、岗位重排、匹配评分、差距分析和简历建议。系统通过确定性规则保证可解释性，
            并在 LLM 不可用时自动降级。
          </p>
          <div class="inline-actions">
            <a class="primary-link" href="https://jobpilot-agent.gentlefield-019d4ae8.eastasia.azurecontainerapps.io/" target="_blank" rel="noreferrer">在线演示</a>
            <a class="outline-link" href="https://github.com/QingPing-s/JobPilot-Agent" target="_blank" rel="noreferrer">查看 GitHub</a>
          </div>
        </header>

        <section class="project-columns">
          <div>
            <h2>系统结构</h2>
            <ol>
              {structure.map((item) => <li>{item}</li>)}
            </ol>
          </div>
          <div>
            <h2>工程证据</h2>
            <ul>
              {evidence.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </section>

        <ul class="project-tags">
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>

        <p class="project-summary">适合展示复杂 RAG-Agent 系统如何从检索、排序、评估、Trace 到云端部署形成完整工程闭环。</p>
      </section>
    </div>
  </article>
</BaseLayout>
