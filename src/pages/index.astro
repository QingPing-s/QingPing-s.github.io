---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sitePath } from "../lib/site.js";

const latestPost = {
  href: sitePath("notes/agent/closed-model-trust-crisis/"),
  title: "企业为什么开始逃离闭源大模型？Anthropic 信任危机背后的技术逻辑",
  description: "从数据边界、平台竞争、Agent 总成本与供应商锁定，分析企业 AI 架构为何转向多模型路由。",
  meta: "Enterprise AI · Model Router · TCO",
};
---

<BaseLayout
  title="QingPing’s Tech Blog"
  description="QingPing’s Tech Blog 记录技术学习、项目实践、工程踩坑，写给未来的自己，也写给同样在探索 AI 的人。"
>
  <section class="profile-hero">
    <video class="profile-hero-video" autoplay muted loop playsinline aria-hidden="true">
      <source src={sitePath("hero-bg.mp4")} type="video/mp4" />
    </video>
    <div class="profile-hero-inner">
      <div class="profile-hero-copy">
        <h1>QingPing’s Tech Blog</h1>
        <p class="profile-copy">
          记录技术学习、项目实践、工程踩坑，写给未来的自己，也写给同样在探索 AI 的人。
        </p>
        <div class="hero-actions profile-actions">
          <a class="primary-link" href={sitePath("notes/")}>进入笔记</a>
          <a class="secondary-link profile-secondary" href={sitePath("projects/")}>浏览项目</a>
        </div>
        <a class="latest-post-card" href={latestPost.href} aria-label={`阅读最新文章：${latestPost.title}`}>
          <span class="latest-post-kicker">Latest Post</span>
          <strong>{latestPost.title}</strong>
          <p>{latestPost.description}</p>
          <small>{latestPost.meta}</small>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
