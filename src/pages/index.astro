---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sitePath } from "../lib/site.js";

const skills = [
  "LangGraph",
  "RAG",
  "Agent Memory",
  "Multi-Agent",
  "FastAPI",
  "LLM Evaluation",
  "MARL",
];
---

<BaseLayout
  title="QingPing-s | AI Agent Developer & Multi-Agent Researcher"
  description="QingPing-s 的 AI Agent 实习和科研展示主页，聚焦 AI Agent、RAG、长期记忆、多智能体协作与多智能体强化学习。"
>
  <section class="profile-hero">
    <div class="profile-hero-inner">
      <p class="eyebrow">AI Agent / RAG / Multi-Agent Systems</p>
      <h1>QingPing-s</h1>
      <p class="profile-subtitle">
        <span>AI Agent Developer</span>
        <span>&amp; Multi-Agent Researcher</span>
      </p>
      <p class="profile-copy">
        专注于 AI Agent、RAG、长期记忆、多智能体协作与多智能体强化学习的工程实践和研究。
      </p>
      <div class="hero-actions profile-actions">
        <a class="primary-link" href={sitePath("projects/")}>查看项目</a>
        <a class="secondary-link profile-secondary" href={sitePath("notes/")}>阅读技术笔记</a>
        <a class="outline-link" href={sitePath("resume.pdf")} target="_blank" rel="noreferrer">
          下载简历
        </a>
      </div>
      <div class="chips profile-tags" aria-label="技术标签">
        {skills.map((skill) => <span>{skill}</span>)}
      </div>
    </div>
  </section>
</BaseLayout>
