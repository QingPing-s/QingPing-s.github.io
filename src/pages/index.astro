---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sitePath } from "../lib/site.js";

const skills = [
  "LangGraph",
  "RAG",
  "Agent Memory",
  "Multi-Agent",
  "FastAPI",
  "LLM Evaluation",
  "MARL",
];

const latestPost = {
  href: sitePath("notes/rag/weighted-rrf/"),
  title: "从消融实验看 Hybrid Retrieval：Weighted RRF 为什么没有赢过 Keyword",
  description: "一次 RAG 检索实验复盘，记录向量召回、关键词召回和加权 RRF 的真实表现。",
  meta: "RAG · Retrieval · Experiment",
};
---

<BaseLayout
  title="QingPing’s tech blog"
  description="QingPing’s tech blog 记录 AI Agent、RAG、长期记忆、多智能体协作与多智能体强化学习相关的工程实践和研究笔记。"
>
  <section class="profile-hero">
    <div class="profile-hero-inner">
      <p class="eyebrow">AI Agent / RAG / Multi-Agent Systems</p>
      <h1>QingPing’s tech blog</h1>
      <p class="profile-copy">
        记录 AI Agent、RAG、长期记忆、多智能体协作与多智能体强化学习相关的工程实践和研究笔记。
      </p>
      <div class="hero-actions profile-actions">
        <a class="primary-link" href={sitePath("notes/")}>进入笔记</a>
        <a class="secondary-link profile-secondary" href={sitePath("projects/")}>浏览项目</a>
      </div>
      <a class="latest-post-card" href={latestPost.href} aria-label={`阅读最新文章：${latestPost.title}`}>
        <span class="latest-post-kicker">Latest Post</span>
        <strong>{latestPost.title}</strong>
        <p>{latestPost.description}</p>
        <small>{latestPost.meta}</small>
      </a>
      <div class="chips profile-tags" aria-label="技术标签">
        {skills.map((skill) => <span>{skill}</span>)}
      </div>
    </div>
  </section>
</BaseLayout>
