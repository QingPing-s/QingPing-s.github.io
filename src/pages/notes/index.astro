---
import NotesLayout from "../../layouts/NotesLayout.astro";
import { noteHref, noteSections, standaloneNotes } from "../../lib/notes.js";
---

<NotesLayout
  title="技术笔记 | QingPing-s"
  description="QingPing-s 的 AI Agent、LangGraph、RAG、Memory、Evaluation、MARL 和编程基础笔记目录。"
>
  <section class="article-page">
    <header class="article-header">
      <p class="eyebrow">Notes</p>
      <h1>技术笔记</h1>
      <p>按学习路径整理 AI Agent 工程、科研和编程基础。暂未展开的主题先保留简洁占位页。</p>
    </header>
    <div class="notes-featured-links">
      {
        standaloneNotes.map(([label, path]) => (
          <a href={noteHref(path)}>{label}</a>
        ))
      }
    </div>
    <div class="notes-directory-grid">
      {
        noteSections.map((section) => (
          <article class="notes-directory-card">
            <h2>{section.title}</h2>
            <ul>
              {
                section.items.map(([label, path]) => (
                  <li>
                    <a href={noteHref(path)}>{label}</a>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </section>
</NotesLayout>
