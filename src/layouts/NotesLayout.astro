---
import BaseLayout from "./BaseLayout.astro";
import { noteHref, noteSections } from "../lib/notes.js";

const {
  title = "技术笔记 | QingPing-s",
  description = "QingPing-s 的 AI Agent、RAG、多智能体和编程技术笔记。",
} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "");
---

<BaseLayout title={title} description={description}>
  <div class="notes-shell">
    <aside class="notes-sidebar" aria-label="技术笔记侧边栏">
      <details class="notes-sidebar-panel" open data-notes-sidebar>
        <summary>技术笔记目录</summary>
        <nav class="notes-nav">
          {
            noteSections.map((section) => (
              <section>
                <h2>{section.title}</h2>
                <ul>
                  {
                    section.items.map(([label, path]) => {
                      const href = noteHref(path);
                      const active = currentPath === href.replace(/\/$/, "");
                      return (
                        <li>
                          <a class:list={{ active }} href={href}>
                            {label}
                          </a>
                        </li>
                      );
                    })
                  }
                </ul>
              </section>
            ))
          }
        </nav>
      </details>
    </aside>
    <div class="notes-content">
      <slot />
    </div>
  </div>
  <script>
    const sidebar = document.querySelector("[data-notes-sidebar]");
    if (sidebar && window.matchMedia("(max-width: 760px)").matches) {
      sidebar.removeAttribute("open");
    }
  </script>
</BaseLayout>
