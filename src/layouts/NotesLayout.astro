---
import BaseLayout from "./BaseLayout.astro";
import { noteHref, noteSections } from "../lib/notes.js";

const {
  title = "技术笔记 | QingPing-s",
  description = "QingPing-s 的 AI Agent、RAG、多智能体和编程技术笔记。",
} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const notesIndexPath = noteHref("").replace(/\/$/, "");
---

<BaseLayout title={title} description={description}>
  <div class="notes-shell">
    <aside class="notes-sidebar" aria-label="技术笔记侧边栏">
      <details class="notes-sidebar-panel" open data-notes-sidebar>
        <summary>技术笔记</summary>
        <nav class="notes-nav">
          {
            noteSections.map((section, sectionIndex) => {
              const sectionActive = section.items.some(([, path]) => {
                const href = noteHref(path);
                return currentPath === href.replace(/\/$/, "");
              });
              const sectionOpen = sectionActive || (currentPath === notesIndexPath && sectionIndex === 0);
              return (
              <details class="notes-nav-section" open={sectionOpen}>
                <summary>{section.title}</summary>
                <ul>
                  {
                    section.items.map(([label, path]) => {
                      const href = noteHref(path);
                      const active = currentPath === href.replace(/\/$/, "");
                      return (
                        <li>
                          <a class:list={{ active }} href={href}>
                            {label}
                          </a>
                        </li>
                      );
                    })
                  }
                </ul>
              </details>
              );
            })
          }
        </nav>
      </details>
    </aside>
    <div class="notes-content">
      <slot />
    </div>
  </div>
  <script>
    const sidebar = document.querySelector("[data-notes-sidebar]");
    if (sidebar && window.matchMedia("(max-width: 760px)").matches) {
      sidebar.removeAttribute("open");
    }
  </script>
</BaseLayout>
