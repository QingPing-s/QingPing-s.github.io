---
import BaseLayout from "./BaseLayout.astro";
import { noteHref, noteSections, standaloneNotes } from "../lib/notes.js";

const {
  title = "技术笔记 | QingPing-s",
  description = "QingPing-s 的 AI Agent、RAG、多智能体和编程技术笔记。",
} = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const notesIndexPath = noteHref("").replace(/\/$/, "");
---

<BaseLayout title={title} description={description}>
  <div class="notes-shell">
    <aside class="notes-sidebar" aria-label="技术笔记侧边栏">
      <details class="notes-sidebar-panel" open data-notes-sidebar>
        <summary>技术笔记</summary>
        <nav class="notes-nav">
          {
            standaloneNotes.map(([label, path]) => {
              const href = noteHref(path);
              const active = currentPath === href.replace(/\/$/, "");
              return (
                <a class:list={["notes-nav-standalone", { active }]} href={href}>
                  {label}
                </a>
              );
            })
          }
          {
            noteSections.map((section, sectionIndex) => {
              const sectionActive = section.items.some(([, path]) => {
                const href = noteHref(path);
                return currentPath === href.replace(/\/$/, "");
              });
              const sectionOpen = sectionActive || (currentPath === notesIndexPath && sectionIndex === 0);
              return (
              <details class="notes-nav-section" open={sectionOpen}>
                <summary>{section.title}</summary>
                <ul>
                  {
                    section.items.map(([label, path]) => {
                      const href = noteHref(path);
                      const active = currentPath === href.replace(/\/$/, "");
                      return (
                        <li>
                          <a class:list={{ active }} href={href}>
                            {label}
                          </a>
                        </li>
                      );
                    })
                  }
                </ul>
              </details>
              );
            })
          }
        </nav>
      </details>
    </aside>
    <div class="notes-content">
      <slot />
    </div>
    <aside class="page-toc" aria-label="本页目录" data-page-toc hidden>
      <strong>On this page</strong>
      <nav></nav>
    </aside>
  </div>
  <script>
    const sidebar = document.querySelector("[data-notes-sidebar]");
    if (sidebar && window.matchMedia("(max-width: 760px)").matches) {
      sidebar.removeAttribute("open");
    }

    const toc = document.querySelector("[data-page-toc]");
    const tocNav = toc?.querySelector("nav");
    const headings = Array.from(document.querySelectorAll(".notes-content h2, .notes-content h3"));
    const slugCounts = new Map();

    function slugify(text) {
      const base = text
        .trim()
        .toLowerCase()
        .replace(/[^\p{Letter}\p{Number}]+/gu, "-")
        .replace(/^-+|-+$/g, "");
      return base || "section";
    }

    if (toc && tocNav && headings.length > 0) {
      const list = document.createElement("ol");
      headings.forEach((heading) => {
        if (!heading.id) {
          const base = slugify(heading.textContent || "");
          const count = slugCounts.get(base) || 0;
          slugCounts.set(base, count + 1);
          heading.id = count === 0 ? base : `${base}-${count + 1}`;
        }

        const item = document.createElement("li");
        const link = document.createElement("a");
        link.href = `#${heading.id}`;
        link.textContent = heading.textContent || "";
        if (heading.tagName === "H3") {
          item.classList.add("toc-subitem");
        }
        item.append(link);
        list.append(item);
      });
      tocNav.append(list);
      toc.hidden = false;
    }
  </script>
</BaseLayout>
